  "keyFeatures": [
    "AI-powered assessment generation using RAG and LLMs",
    "Bloom's taxonomy cognitive level classification",
    "PDF document processing and vector embeddings",
    "User authentication and assessment history",
    "Customizable question distribution across cognitive levels",
    "Export assessments to PDF and DOCX formats"
  ],
  "publicApiSurface": [
    "POST /api/signup - User registration",
    "POST /api/login - User authentication",
    "GET /api/me - Get current user",
    "POST /api/forgot-password - Request password reset",
    "POST /api/reset-password - Reset password",
    "POST /chunking - Upload and process PDF documents",
    "GET /chunking/status - Check document processing status",
    "POST /chat - Generate assessment questions",
    "GET /job_status - Check assessment generation status",
    "POST /api/assessments/save - Save generated assessment",
    "GET /api/assessments/history - Get user's assessment history",
    "GET /api/assessments/{assessment_id} - Get specific assessment"
  ]
